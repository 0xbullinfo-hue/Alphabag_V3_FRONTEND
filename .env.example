
# ===========================================
# ALPHABAG V3 - ENVIRONMENT CONFIGURATION
# ===========================================

# ===== FRONTEND CONFIGURATION =====
# WalletConnect Project ID (required)
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID_HERE

# API Base URL — Single source of truth for the backend domain.
# Leave EMPTY for local dev (Vite proxy will forward /api/* to localhost:3003).
# Set to your backend domain for production cross-domain deployment.
# Example: https://api.alphabag.io
VITE_API_BASE_URL=

# Data Source Mode
# MOCK = force simulated/demo data only
# LIVE = force live API only
# AUTO = try live first then fallback to mock-safe UX
VITE_DATA_MODE=AUTO

# Optional market proxy path on backend (used by MarketService)
# Example: /api/market or https://api.alphabag.io/api/market
VITE_MARKET_PROXY_BASE_URL=/api/market

# Launch Mode
# teaser = Landing page only, no backend required (pre-launch hype)
# full   = Full app with auth and backend (testnet / mainnet)
# Leave empty or set to 'full' for the complete app experience.
VITE_LAUNCH_MODE=teaser

# Alchemy API Key (required for blockchain interactions)
VITE_ALCHEMY_API_KEY=

# ===== TOKEN GATING CONFIGURATION =====
# Empty until BAG token is deployed
# Updated at deployment time

# Token Contract Addresses
VITE_BAG_TOKEN_ADDRESS_MAINNET=
VITE_BAG_TOKEN_ADDRESS_TESTNET=

# Minimum BAG Required for Premium Access
VITE_MIN_BAG_REQUIRED=

# Feature Flags
VITE_ENABLE_TOKEN_GATING=false
VITE_ENVIRONMENT=testnet

# ===== ADMIN CONFIGURATION =====
# Comma-separated list of admin wallet addresses (Server-side only)
ADMIN_WALLETS=0x_YOUR_ADMIN_WALLET_ADDRESS_HERE

# ===== PREMIUM API KEYS =====
# These are optional for testnet but required for mainnet features

# Nansen - Real whale transaction tracking
NANSEN_API_KEY=

# Block Explorer APIs - Real transaction history
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# ===== BACKEND CONFIGURATION =====
# Prisma requires a valid connection string to introspect or migrate.
DATABASE_URL=postgresql://postgres:password@localhost:5432/alphabag

# Authentication (MUST BE LONG AND RANDOM IN PRODUCTION)
JWT_SECRET=generate_a_strong_random_secret_for_production

# Blockchain Transactions (for sendEvmTokens)
# WARNING: NEVER store raw private keys in environment variables in production.
# USE AWS KMS, HashiCorp Vault, or equivalent secure key management.
PRIVATE_KEY=

# CORS — The frontend domain allowed to call this backend.
# Must match exactly (no trailing slash).
# Example: https://app.alphabag.io
# Leave as http://localhost:3005 only for local development — NEVER * in production.
FRONTEND_URL=http://localhost:3005

# Telegram Bot (for whale alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== DEPLOYMENT GUIDE =====
#
# TESTNET DEPLOYMENT (All features available, no token check):
# - VITE_ENVIRONMENT=testnet
# - VITE_ENABLE_TOKEN_GATING=false
# - VITE_BAG_TOKEN_ADDRESS_TESTNET= (leave empty)
# - ADMIN_WALLETS=your_admin_wallet
#
# MAINNET DEPLOYMENT (Real token gating, premium features):
# - VITE_ENVIRONMENT=production
# - VITE_ENABLE_TOKEN_GATING=true
# - VITE_BAG_TOKEN_ADDRESS_MAINNET=0x... (deployed token address)
# - VITE_MIN_BAG_REQUIRED=1000
# - NANSEN_API_KEY=your_nansen_key
# - ETHERSCAN_API_KEY=your_etherscan_key
# - BSCSCAN_API_KEY=your_bscscan_key
#
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ===== CROSS-DOMAIN DEPLOYMENT GUIDE =====
#
# FRONTEND (Netlify / Vercel):
#   VITE_API_BASE_URL=https://api.alphabag.io
#   All other VITE_* vars as normal
#
# BACKEND (Railway / Render / VPS):
#   FRONTEND_URL=https://app.alphabag.io
#   JWT_SECRET=<strong secret>
#   DATABASE_URL=<your mongo/postgres URI>
#   PORT=3003 (or whatever your host assigns)
#
# HOW IT WORKS:
#   - Frontend axios client (api.ts) prefixes all /api/* calls with VITE_API_BASE_URL
#   - Backend CORS middleware allows only the FRONTEND_URL origin
#   - JWT tokens are attached automatically via the axios request interceptor
#   - The neural-core streaming endpoint uses fetch() but also reads VITE_API_BASE_URL
